# Copia este archivo como .env para desarrollo local (no lo subas a git).

# Conexión a PostgreSQL. En Railway se inyecta automáticamente al añadir la base de datos.
# Si lo dejas vacío en local, el servidor usa un almacén EN MEMORIA (datos se pierden al reiniciar).
DATABASE_URL=

# Contraseña para entrar al panel /admin
ADMIN_PASSWORD=cambia-esta-clave

# Secreto para firmar las sesiones del admin (usa una cadena larga y aleatoria)
JWT_SECRET=pon-aqui-una-cadena-larga-y-aleatoria

# Puerto (Railway lo define solo; en local por defecto 3000)
PORT=3000

# SSL de Postgres: 'true' fuerza SSL, 'false' lo desactiva. Por defecto se detecta solo.
# PGSSL=
